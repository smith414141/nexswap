rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }
    match /withdrawals/{withdrawalId} {
      // Validate that amount is numeric and greater than 0
      allow create: if request.auth != null 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.amount is number 
        && request.resource.data.amount > 0;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read, update: if isAdmin();
    }
    match /wallets/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Remove update and create for users to prevent direct balance manipulation
      allow read, write: if isAdmin();
    }
    match /p2pOrders/{orderId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && (resource.data.buyerUid == request.auth.uid
            || resource.data.sellerUid == request.auth.uid
            || resource.data.merchantUid == request.auth.uid);
      allow read, update: if isAdmin();
    }
    
    match /transactions/{id} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow read, create: if isAdmin();
    }
    match /chats/{chatId} {
      allow create, read, update: if request.auth != null
        && (resource == null || resource.data.userId == request.auth.uid);
      allow read, write: if isAdmin();
    }
    match /directMessages/{msgId} {
  allow create: if isAdmin();
  allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
  allow read, write: if isAdmin();
}

match /announcementReads/{userId} {
  allow read, write: if request.auth != null && request.auth.uid == userId;
  allow read, write: if isAdmin();
}
    match /announcements/{annId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.merchantUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.merchantUid == request.auth.uid;
      allow read, write: if isAdmin();
    }
    match /listingOverrides/{listingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
     match /stakingPositions/{posId} {
    allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
    allow read, write: if isAdmin();
  }
 
  match /addressBook/{userId} {
    allow read, write: if request.auth != null && request.auth.uid == userId;
    allow read, write: if isAdmin();
  }
  match /referrals/{id} { allow read, write: if request.auth != null && resource.data.referrerId == request.auth.uid; allow read, write: if isAdmin(); }
match /cards/{userId} { allow read, write: if request.auth != null && request.auth.uid == userId; }
match /cardTransactions/{id} { allow create, read: if request.auth != null && request.resource.data.userId == request.auth.uid; allow read: if request.auth != null && resource.data.userId == request.auth.uid; }
match /tradeHistory/{id} { allow create: if request.auth != null && request.resource.data.userId == request.auth.uid; allow read: if request.auth != null && resource.data.userId == request.auth.uid; }
match /leaderboard/{id} { allow read: if true; allow write: if isAdmin(); }
match /priceAlerts/{id} { allow create, read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid); }
  }
} 
